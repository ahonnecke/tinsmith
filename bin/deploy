#!/usr/bin/env bash
#
# deploy — ship the current app to Fly.io (hvac3.fly.dev). One command.
#
# Finds flyctl even if it isn't on PATH, logs you in if you aren't, builds on
# Fly's remote builders (no local Docker), then smoke-tests. The release step
# runs db/migrate.mjs (which also corrects the demo-login email).
#
#   npm run deploy      (from app/)      —or—      bin/deploy
set -euo pipefail

FLY="$(command -v flyctl || true)"
[ -n "$FLY" ] || FLY="$HOME/.fly/bin/flyctl"
[ -x "$FLY" ] || { echo "flyctl not installed. Once: curl -L https://fly.io/install.sh | sh"; exit 1; }

if ! "$FLY" auth whoami >/dev/null 2>&1; then
  echo "→ logging in to Fly (authorize the URL it prints — a phone browser is fine)"
  "$FLY" auth login
fi

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT/app"
echo "→ deploying to hvac3.fly.dev (remote build)…"
"$FLY" deploy --remote-only

echo "→ health:"
curl -fsS https://hvac3.fly.dev/api/health && echo || echo "(not green yet — retry in a few seconds)"
